{
  "manifest_version": 3,
  "name": "RoleLens",
  "version": "0.1.0",
  "description": "Hide or classify job cards on wanted.co.kr by exact company name.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.wanted.co.kr/*"],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html"
}
